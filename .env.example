# DeepRouter — Environment Configuration Template
# Usage: cp .env.example .env  then fill in real values.
# NEVER commit .env to version control.

# ── Runtime ───────────────────────────────────────────────────
ENV=development                        # "development" | "production"
LOG_LEVEL=INFO

# ── Infrastructure ────────────────────────────────────────────
REDIS_URL=redis://localhost:6381/0
CELERY_BACKEND_URL=redis://localhost:6381/1
POSTGRES_URL=postgresql://admin:password123@localhost:5434/deeprouter

# ── LLM Routing (LiteLLM — supports OpenAI, Anthropic, local) ─
LITELLM_API_KEY=sk-your-key-here
DEFAULT_FAST_MODEL=gpt-4o-mini
CODE_MODEL=gpt-4o

# ── Authentication ────────────────────────────────────────────
DEV_API_KEY=dev-secret-key             # Only valid when ENV=development
ADMIN_SECRET=change-me-in-production

# ── Security ─────────────────────────────────────────────────
ADMIN_ALLOWED_IPS=127.0.0.1,::1       # Comma-separated IPs / CIDRs (prod only)
MAX_TPM=6000                           # Token-per-minute rate limit per user
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Embedding model cache ─────────────────────────────────────
SENTENCE_TRANSFORMERS_HOME=.model_cache
HF_HOME=.model_cache
